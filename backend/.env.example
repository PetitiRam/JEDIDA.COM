PORT=5000
NODE_ENV=development

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=jedida_marketplace

# Auth
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for share links / CORS / password reset links)
FRONTEND_URL=http://localhost:5173

# Public URL of this backend (used to build shareable shop links like /shop/:slug)
PUBLIC_API_URL=http://localhost:5000

# Role upgrade verification fee (mobile money), in platform base currency
UPGRADE_VERIFICATION_FEE=1000

# Email (password reset) — plug in SendGrid/SMTP later
EMAIL_FROM=no-reply@jedidamarketplace.com

# SMS / OTP provider (e.g. Africa's Talking, Twilio) — plug in later
SMS_PROVIDER_API_KEY=

# Payment providers — plug in for Phase 4
STRIPE_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
DPO_COMPANY_TOKEN=
COINBASE_COMMERCE_API_KEY=
